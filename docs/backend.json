
{
  "entities": {
    "Issuance": {
      "title": "Medicine Issuance Record",
      "description": "A record of medicine distributed to a patient in the facility.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Employee full name" },
        "email": { "type": "string", "format": "email", "description": "Employee work email" },
        "age": { "type": "number", "description": "Employee age" },
        "gender": { "type": "string", "description": "Employee gender" },
        "department": { "type": "string", "description": "BPO Department (e.g., Sales, Operations, IT)" },
        "position": { "type": "string", "description": "Employee position or role" },
        "chiefComplaints": { "type": "string", "description": "Symptoms or complaints" },
        "date": { "type": "string", "format": "date", "description": "Date of issuance (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Time of issuance (HH:MM)" },
        "medicineTaken": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "dosage": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "age", "gender", "department", "position", "chiefComplaints", "medicineTaken", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/issuances/{issuanceId}": {
      "schema": "Issuance",
      "description": "Collection of medicine issuance records for the company clinic."
    }
  }
}
